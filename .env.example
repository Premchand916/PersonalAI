# ─────────────────────────────────────────────────────────────────────────────
# IntelligenceOS — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
#
# SETUP:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in REAL values below (never commit .env — it's in .gitignore)
#   3. secrets_guard.validate_env() will verify these at every startup
#
# SECURITY: This file contains ZERO real secrets. All values are placeholders.
# ─────────────────────────────────────────────────────────────────────────────


# ── Web Search ────────────────────────────────────────────────────────────────
# Get your key at: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here


# ── Local LLM (Ollama) ────────────────────────────────────────────────────────
# Run: ollama pull llama3.1:8b
# Recommended for IntelligenceOS v2 (larger context than 3.2:1b)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_FALLBACK_MODEL=llama3.2:1b


# ── Telegram Delivery ─────────────────────────────────────────────────────────
# Create a bot at: https://t.me/BotFather
# Get chat ID by messaging your bot and calling:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ── IntelligenceOS v2 Settings ────────────────────────────────────────────────
# Importance score (0-10) above which AlertAgent sends IMMEDIATE alert
# Default: 7.0 — tune this based on how many alerts you want
ALERT_IMPORTANCE_THRESHOLD=7.0

# Morning brief schedule (24h format, system local time)
# Default: 09:00 — change to your preferred wake-up + buffer time
BRIEF_SCHEDULE_HOUR=9
BRIEF_SCHEDULE_MINUTE=0
